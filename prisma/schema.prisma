generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  assetId           BigInt          @id
  name              String
  imageUrl          String?
  description       String?
  manipulated       Boolean         @default(false)
  isLimitedUnique   Boolean?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  inventoryItems    InventoryItem[]
  priceHistory      PriceHistory[]
  sales             Sale[]
  watchlist         Watchlist[]
  notifications     Notification[]
  snipeConfigs      SnipeConfig[]
  manipulatedAt     DateTime?
  manipulatedRap    Float?
  flags             ManipulationFlag[]
  tradeAdItems      TradeAdItem[]

  @@index([assetId])
}

model PriceHistory {
  id           String   @id @default(cuid())
  itemId       BigInt
  price        Float
  rap          Float?
  lowestResale Float?
  salesVolume  Int?
  timestamp    DateTime @default(now())
  item         Item     @relation(fields: [itemId], references: [assetId], onDelete: Cascade)

  @@index([itemId, timestamp])
  @@index([timestamp])
}

model Sale {
  id       String   @id @default(cuid())
  itemId   BigInt
  oldRap   Float
  newRap   Float
  saleDate DateTime @default(now())
  item     Item     @relation(fields: [itemId], references: [assetId], onDelete: Cascade)

  @@index([itemId, saleDate])
  @@index([saleDate])
}

model User {
  robloxUserId         BigInt              @id
  username             String
  displayName          String?
  avatarUrl            String?
  avatarFullBodyUrl    String?
  description          String?
  role                 String              @default("user")
  authMethod           String?             // "bio" or "oauth"
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  discordId            String?
  discordUsername      String?
  discordNotifications Boolean             @default(false)
  inventorySnapshots   InventorySnapshot[]
  sessions             Session[]
  watchlist            Watchlist[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  snipeConfigs         SnipeConfig[]
  posts                Post[]
  newsReads            NewsRead[]
  flagReviews          ManipulationFlag[]
  tradeAds             TradeAd[]
}

model InventorySnapshot {
  id          String          @id @default(cuid())
  userId      BigInt
  createdAt   DateTime        @default(now())
  totalRAP    Float?
  totalItems  Int?
  uniqueItems Int?
  items       InventoryItem[]
  user        User            @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  // DB-level unique index on (userId, DATE(createdAt)) applied manually — prevents duplicate daily snapshots
  // Created with: CREATE UNIQUE INDEX "InventorySnapshot_userId_date_unique" ON "InventorySnapshot" ("userId", DATE("createdAt"))
}

model InventoryItem {
  snapshotId    String
  assetId       BigInt
  userAssetId   BigInt
  scannedAt     DateTime          @default(now())
  uaidCreatedAt DateTime?         // When this UAID was originally created (item first purchased)
  uaidUpdatedAt DateTime?         // When this UAID last changed hands = trade timestamp (from Roblox owners API)
  isOnHold      Boolean?
  serialNumber  Int?
  lastSeenAt    DateTime?
  item          Item              @relation(fields: [assetId], references: [assetId])
  snapshot      InventorySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
 
  @@id([snapshotId, userAssetId])
  @@index([snapshotId])
  @@index([assetId])
  @@index([userAssetId])
  @@index([serialNumber])
  @@index([uaidCreatedAt])
  @@index([uaidUpdatedAt])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       BigInt
  accessToken  String?
  authMethod   String?  // "bio" or "oauth"
  user         User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionToken])
  @@index([userId])
}

model Watchlist {
  userId         BigInt
  itemId         BigInt
  createdAt      DateTime @default(now())
  priceAlerts    Boolean  @default(false)
  salesAlerts    Boolean  @default(false)
  tradeAlerts    Boolean  @default(false)
  tradeAlertType String   @default("contains")
  user           User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  item           Item     @relation(fields: [itemId], references: [assetId], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    BigInt
  itemId    BigInt
  type      String
  message   String
  oldValue  Float?
  newValue  Float?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [assetId], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    BigInt
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)

  @@index([userId])
}

model SnipeConfig {
  id        String   @id @default(cuid())
  userId    BigInt
  assetId   BigInt?
  minDeal   Float    @default(10)
  minPrice  Float?
  maxPrice  Float?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  item      Item?    @relation(fields: [assetId], references: [assetId], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model SnipeDeal {
  id        String   @id @default(cuid())
  assetId   BigInt
  name      String
  imageUrl  String?
  price     Float
  rap       Float
  deal      Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ScanJob {
  id          String   @id @default(cuid())
  assetId     BigInt?
  userId      BigInt?
  type        String   @default("owners") // "owners" | "inventory"
  status      String   @default("pending") // "pending" | "running" | "stopped" | "done"
  total       Int      @default(0)
  processed   Int      @default(0)
  failed      Int      @default(0)
  pagesFound  Int      @default(0)
  currentUser String?
  startedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([assetId, status])
  @@index([userId, status])
  @@index([type, status])
  @@index([startedAt])
}

model Post {
  id             Int       @id @default(autoincrement())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  authorId       BigInt
  published      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  deletedById    BigInt?
  deletedReason  String?
  author         User      @relation(fields: [authorId], references: [robloxUserId], onDelete: Cascade)
  newsReads      NewsRead[]

  @@index([slug])
  @@index([authorId])
  @@index([createdAt])
  @@index([deletedAt])
}

model NewsRead {
  userId    BigInt
  postId    Int
  readAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([userId])
  @@index([postId])
}

model ManipulationFlag {
  id              String    @id @default(cuid())
  assetId         BigInt
  flagType        String    @default("manipulation") // "manipulation" | "unmark_suggestion"
  status          String    @default("pending")       // "pending" | "accepted" | "dismissed"
  reason          String
  detectionMethod String?   // "rap_growth" | "sale_above_best" | "unmark_suggestion"
  rapAtFlag       Float
  rapGrowthPct    Float?
  saleDate        DateTime? // for sale_above_best: the exact sale date, used for deduplication
  reviewedBy      BigInt?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  item            Item      @relation(fields: [assetId], references: [assetId], onDelete: Cascade)
  reviewer        User?     @relation(fields: [reviewedBy], references: [robloxUserId])

  @@index([assetId, status])
  @@index([flagType, status])
  @@index([createdAt])
  @@index([assetId, detectionMethod, saleDate])
}

model TradeAd {
  id           Int           @id @default(autoincrement())
  userId       BigInt
  note         String?
  active       Boolean       @default(true)
  offerRobux   Int           @default(0)
  requestRobux Int           @default(0)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [robloxUserId], onDelete: Cascade)
  items        TradeAdItem[]

  @@index([userId, active])
  @@index([createdAt])
  @@index([deletedAt])
}

model TradeAdItem {
  id           String   @id @default(cuid())
  tradeAdId    Int
  side         String   // "offer" | "request"
  assetId      BigInt
  userAssetId  BigInt?  // offer only, null = any copy
  serialNumber Int?     // offer only, denormalized for display
  tradeAd      TradeAd  @relation(fields: [tradeAdId], references: [id], onDelete: Cascade)
  item         Item     @relation(fields: [assetId], references: [assetId])

  @@index([tradeAdId])
  @@index([assetId])
}

model UaidCursorCache {
  id        String   @id @default(cuid())
  assetId   BigInt
  cursor    String?  // ← just add the ?
  lastUaid  BigInt
  pageNum   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([assetId, lastUaid])
  @@index([assetId, lastUaid])
}